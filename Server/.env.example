MONGO_URI=mongodb://localhost:27017/janumang_saas
PORT=5000
SENTRY_DSN=

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here

# ─── Google Integrations ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_CALENDAR_ID=your_google_calendar_id
GOOGLE_SERVICE_KEY_PATH=./service-key.json

FRONTEND_URL=http://localhost:3001

# ─── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=JanUmang <no-reply@janumang.com>

# ─── Razorpay Payment ──────────────────────────────────────────────────────────
# Get these from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Razorpay Plan IDs (from dashboard.razorpay.com/app/subscriptions/plans)
RAZORPAY_PLAN_BASIC_MONTHLY=plan_xxxxxxxx
RAZORPAY_PLAN_BASIC_YEARLY=plan_xxxxxxxx
RAZORPAY_PLAN_PRO_MONTHLY=plan_xxxxxxxx
RAZORPAY_PLAN_PRO_YEARLY=plan_xxxxxxxx
RAZORPAY_PLAN_ENT_MONTHLY=plan_xxxxxxxx
RAZORPAY_PLAN_ENT_YEARLY=plan_xxxxxxxx
